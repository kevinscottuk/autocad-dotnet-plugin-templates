# Default: store everything as LF
* text=auto eol=lf

# Windows-specific scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Shell scripts
*.sh text eol=lf

# C# / .NET
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf

# JSON / YAML / config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files (important!)
*.png binary
*.jpg binary
*.exe binary
*.dll binary
